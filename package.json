{
  "name": "vibe-auth",
  "type": "module",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run dev:be & bun run dev:fe",
    "dev:be": "cd apps/backend && bun run dev",
    "dev:fe": "cd apps/frontend && bun run dev",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "lint": "bun x eslint .",
    "format": "bun x prettier --write .",
    "install:all": "bun install"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "eslint": "latest",
    "prettier": "latest",
    "typescript": "^5"
  }
}
