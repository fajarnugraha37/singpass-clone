---
import BaseLayout from '../layouts/BaseLayout.astro';
import LoginForm from '../components/LoginForm.svelte';
import TwoFactorForm from '../components/TwoFactorForm.svelte';

// We use client-side state to toggle between login and 2FA
---

<BaseLayout title="Log In - Singpass">
  <div class="container mx-auto px-4 py-12 flex-grow flex flex-col items-center justify-center">
    <div class="w-full max-w-md bg-white p-8 border border-gray-200 shadow-sm" id="auth-container">
      
      <!-- Authorization Purpose Info -->
      <div id="auth-purpose" class="hidden mb-6 p-4 bg-gray-50 border-l-4 border-red-600">
        <p class="text-xs font-bold text-gray-500 uppercase tracking-wider mb-1">Purpose of Data Access</p>
        <p id="purpose-text" class="text-sm text-gray-700 italic"></p>
      </div>

      <div id="login-section">
        <h1 id="login-title" class="text-2xl font-bold text-gray-900 mb-6">Log in</h1>
        <LoginForm client:load onSuccess={() => {
          document.getElementById('login-section')?.classList.add('hidden');
          document.getElementById('2fa-section')?.classList.remove('hidden');
        }} />
      </div>

      <div id="2fa-section" class="hidden">
        <h1 class="text-2xl font-bold text-gray-900 mb-6">2-Factor Authentication</h1>
        <TwoFactorForm client:load />
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  import { client } from '../lib/rpc';

  async function updateAuthInfo() {
    try {
      const res = await client.api.auth.session.$get();
      if (res.ok) {
        const data = await res.json();
        
        // Update Title with Application Name
        const titleEl = document.getElementById('login-title');
        if (titleEl && data.clientName) {
          titleEl.textContent = `Log in to ${data.clientName}`;
        }

        // Update Purpose
        const purposeEl = document.getElementById('auth-purpose');
        const purposeTextEl = document.getElementById('purpose-text');
        if (purposeEl && purposeTextEl && data.purpose) {
          purposeTextEl.textContent = data.purpose;
          purposeEl.classList.remove('hidden');
        }
      }
    } catch (e) {
      console.error('Failed to fetch session info:', e);
    }
  }

  // Run on mount
  updateAuthInfo();

  // Optional: Handle back button or page refreshes if needed
</script>
