---
import Layout from '../../layouts/Layout.astro';
import GodMode from '../../components/admin/GodMode.svelte';
import Header from '../../components/developer/Header.svelte';
---

<Layout title="Admin God Mode | Vibe-Auth">
	<main class="min-h-screen bg-gray-50">
    <Header client:load />
    <div class="max-w-7xl mx-auto py-10 px-4 sm:px-6 lg:px-8">
      <div class="mb-8">
        <h1 class="text-3xl font-bold text-gray-900">Admin God Mode</h1>
        <p class="mt-2 text-sm text-gray-600">Global oversight of the OIDC/FAPI ecosystem.</p>
      </div>
      
      <GodMode client:load />
    </div>
	</main>
</Layout>
