---
import BaseLayout from '../layouts/BaseLayout.astro';
import LoginTabs from '../components/LoginTabs.svelte';
---

<BaseLayout title="Singpass | Trusted Digital Identity">
  <div class="bg-singpass-light flex-grow">
    <div class="container-singpass py-12 md:py-20 flex flex-col lg:flex-row items-center justify-between gap-12">
      <!-- Left side: Hero Text -->
      <div class="max-w-xl text-center lg:text-left">
        <h1 class="text-4xl md:text-5xl font-bold text-singpass-dark leading-tight mb-6">
          Log in with Singpass
        </h1>
        <p class="text-lg text-singpass-gray-500 mb-8 leading-relaxed">
          Access thousands of government and private sector services securely with your trusted digital identity.
        </p>
        
        <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start">
          <div class="flex items-center gap-3 bg-white p-4 rounded-xl shadow-sm border border-singpass-gray-200">
            <div class="w-10 h-10 bg-singpass-red rounded-lg flex items-center justify-center text-white font-bold italic">S</div>
            <div>
              <p class="text-[10px] text-singpass-gray-400 font-bold uppercase tracking-wider">Get the app</p>
              <p class="text-xs font-bold text-singpass-dark">Singpass App</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Right side: Login Card -->
      <div class="w-full max-w-[420px]">
        <LoginTabs client:load />
      </div>
    </div>
  </div>
</BaseLayout>
