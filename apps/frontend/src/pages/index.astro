---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Singpass | Trusted Digital Identity">
  <div class="bg-singpass-light flex-grow">
    <div class="container-singpass py-12 md:py-20 flex flex-col lg:flex-row items-center justify-between gap-12">
      <!-- Left side: Hero Text -->
      <div class="max-w-xl text-center lg:text-left">
        <h1 class="text-4xl md:text-5xl font-bold text-singpass-dark leading-tight mb-6">
          Log in with Singpass
        </h1>
        <p class="text-lg text-singpass-gray-500 mb-8 leading-relaxed">
          Access thousands of government and private sector services securely with your trusted digital identity.
        </p>
        
        <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start">
          <div class="flex items-center gap-3 bg-white p-4 rounded-xl shadow-sm border border-singpass-gray-200">
            <div class="w-10 h-10 bg-singpass-red rounded-lg flex items-center justify-center text-white font-bold italic">S</div>
            <div>
              <p class="text-[10px] text-singpass-gray-400 font-bold uppercase tracking-wider">Get the app</p>
              <p class="text-xs font-bold text-singpass-dark">Singpass App</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Right side: Login Card Placeholder -->
      <div class="w-full max-w-[420px]">
        <div class="bg-white rounded-2xl shadow-xl border border-singpass-gray-200 overflow-hidden min-h-[500px] flex flex-col items-center justify-center p-8 text-center border-dashed">
          <div class="w-16 h-16 bg-singpass-gray-100 rounded-full flex items-center justify-center mb-4">
             <svg class="w-8 h-8 text-singpass-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
          </div>
          <h2 class="text-xl font-bold text-singpass-dark mb-2">Login Interface</h2>
          <p class="text-sm text-singpass-gray-500 mb-6">
            The interactive login tabs and form will be implemented in the next phases.
          </p>
          <div class="w-full h-2 bg-singpass-gray-100 rounded-full overflow-hidden">
            <div class="w-1/3 h-full bg-singpass-red animate-pulse"></div>
          </div>
          <p class="text-[10px] text-singpass-gray-400 mt-4 font-bold uppercase tracking-widest">In Development</p>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
